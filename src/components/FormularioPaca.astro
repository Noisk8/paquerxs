---
const colectivos = [
  'Paquerxs del Parkway',
  'Paquerxs de San Luis',
  'Paquerxs del Neuque',
  'Paquerxs de La Marchita',
  'Paquerxs Armenia',
];
---

<div id="form-skeleton" class="space-y-5 max-w-2xl mx-auto">
  <div class="skeleton h-7 w-48 rounded bg-stone-200 dark:bg-stone-700"></div>
  <div class="space-y-2">
    <div class="skeleton h-4 w-32 rounded bg-stone-200 dark:bg-stone-700"></div>
    <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
  </div>
  <div class="space-y-2">
    <div class="skeleton h-4 w-24 rounded bg-stone-200 dark:bg-stone-700"></div>
    <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div class="space-y-2">
      <div class="skeleton h-4 w-20 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    </div>
    <div class="space-y-2">
      <div class="skeleton h-4 w-20 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    </div>
  </div>
  <div class="bg-stone-100 dark:bg-stone-800 rounded-xl p-4 space-y-3">
    <div class="skeleton h-4 w-24 rounded bg-stone-200 dark:bg-stone-700"></div>
    <div class="skeleton h-[250px] w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    <div class="grid grid-cols-2 gap-3">
      <div class="skeleton h-10 rounded-lg bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-10 rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    </div>
  </div>
  <div class="space-y-2">
    <div class="skeleton h-4 w-36 rounded bg-stone-200 dark:bg-stone-700"></div>
    <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
  </div>
  <div class="space-y-2">
    <div class="skeleton h-4 w-40 rounded bg-stone-200 dark:bg-stone-700"></div>
    <div class="skeleton h-20 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
  </div>
  <div class="skeleton h-12 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
</div>

<form id="form-paca" class="space-y-5 max-w-2xl mx-auto hidden" novalidate>
  <h2 class="text-2xl font-bold text-emerald-800 dark:text-emerald-400 mb-6">Registrar Nueva Paca</h2>

  <div>
    <label for="nombre" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1">Nombre de la paca *</label>
    <input type="text" id="nombre" name="nombre" required placeholder="Ej: Paca Biodigestora Silva Parkway 27-07-25"
      class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm sm:text-base focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
    <p class="error text-xs text-red-600 dark:text-red-400 mt-1 hidden">Ingresa el nombre de la paca</p>
  </div>

  <div>
    <label for="colectivo" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1">Colectivo *</label>
    <select id="colectivo" name="colectivo" required
      class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm sm:text-base focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none bg-white">
      <option value="">Seleccionar Colectivo</option>
      {colectivos.map((c) => (<option value={c}>{c}</option>))}
    </select>
    <p class="error text-xs text-red-600 dark:text-red-400 mt-1 hidden">Selecciona un colectivo</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="peso" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1">Peso (kg) *</label>
      <input type="number" id="peso" name="peso" step="0.1" min="0.1" required placeholder="Ej: 150"
        class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm sm:text-base focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
      <p class="error text-xs text-red-600 dark:text-red-400 mt-1 hidden">Ingresa el peso (minimo 0.1 kg)</p>
    </div>
    <div>
      <label for="fecha_inicio" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1">Fecha de inicio *</label>
      <input type="date" id="fecha_inicio" name="fecha_inicio" required
        class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm sm:text-base focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
      <p class="error text-xs text-red-600 dark:text-red-400 mt-1 hidden">Selecciona una fecha</p>
    </div>
  </div>

  <div class="bg-stone-100 dark:bg-stone-800 rounded-xl p-4 space-y-3">
    <div class="flex items-center justify-between">
      <label class="text-sm font-medium text-stone-700 dark:text-stone-300">Ubicacion *</label>
      <button type="button" id="btn-ubicacion"
        class="inline-flex items-center gap-1.5 text-xs sm:text-sm bg-emerald-600 hover:bg-emerald-700 text-white px-3 py-1.5 rounded-lg transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
        </svg>
        <span id="btn-ubicacion-texto">Mi ubicacion</span>
      </button>
    </div>
    <div id="ubicacion-estado" class="hidden text-xs text-stone-500 dark:text-stone-400"></div>

    <div id="mapa-form" class="w-full h-[250px] sm:h-[300px] rounded-lg border border-stone-300 dark:border-stone-600 z-0"></div>
    <p class="text-xs text-stone-400 dark:text-stone-500 italic">Arrastra el pin para ajustar la posicion exacta</p>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <label for="coordenadas_lat" class="block text-xs text-stone-500 dark:text-stone-400 mb-1">Latitud *</label>
        <input type="number" id="coordenadas_lat" name="coordenadas_lat" step="0.0000001" required placeholder="4.6287778"
          class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none bg-white" />
      </div>
      <div>
        <label for="coordenadas_lng" class="block text-xs text-stone-500 dark:text-stone-400 mb-1">Longitud *</label>
        <input type="number" id="coordenadas_lng" name="coordenadas_lng" step="0.0000001" required placeholder="-74.0752778"
          class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none bg-white" />
      </div>
    </div>
    <p class="error text-xs text-red-600 dark:text-red-400 hidden">Ubica la paca en el mapa o ingresa las coordenadas</p>
    <button type="button" id="btn-mover-pin"
      class="w-full mt-2 text-xs bg-stone-200 dark:bg-stone-700 hover:bg-stone-300 dark:hover:bg-stone-600 text-stone-700 dark:text-stone-300 px-3 py-1.5 rounded-lg transition-colors cursor-pointer">
      Mover pin a estas coordenadas
    </button>
  </div>

  <div>
    <label for="participantes" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1">Numero de participantes *</label>
    <input type="number" id="participantes" name="participantes" min="1" required placeholder="Ej: 10"
      class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm sm:text-base focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
    <p class="error text-xs text-red-600 dark:text-red-400 mt-1 hidden">Ingresa el numero de participantes (minimo 1)</p>
  </div>

  <div>
    <label for="informacion" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1">Informacion adicional *</label>
    <textarea id="informacion" name="informacion" rows="3" required placeholder="Notas, observaciones..."
      class="field w-full rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2.5 text-sm sm:text-base focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none resize-y"></textarea>
    <p class="error text-xs text-red-600 dark:text-red-400 mt-1 hidden">Agrega informacion sobre la paca</p>
  </div>

  <div id="mensaje" class="hidden rounded-lg p-4 text-sm"></div>

  <button type="submit"
    class="w-full bg-emerald-700 hover:bg-emerald-800 text-white font-semibold py-3 px-4 rounded-lg transition-colors cursor-pointer text-sm sm:text-base">
    Guardar Paca
  </button>
</form>

<script is:inline>
(function() {
  const formSkeleton = document.getElementById('form-skeleton');
  const form = document.getElementById('form-paca');
  formSkeleton.classList.add('hidden');
  form.classList.remove('hidden');

  const mensaje = document.getElementById('mensaje');
  const btn = document.getElementById('btn-ubicacion');
  const btnTxt = document.getElementById('btn-ubicacion-texto');
  const estado = document.getElementById('ubicacion-estado');
  const latIn = document.getElementById('coordenadas_lat');
  const lngIn = document.getElementById('coordenadas_lng');

  var map = L.map('mapa-form', { zoomControl: false }).setView([4.64, -74.075], 14);
  L.control.zoom({ position: 'topright' }).addTo(map);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap',
    maxZoom: 19,
  }).addTo(map);

  var marker = null;
  var accuracyCircle = null;
  var watchId = null;
  var bestAccuracy = Infinity;

  var defaultIcon = L.icon({
    iconUrl: '/icons/paca.png',
    iconSize: [32, 32],
    iconAnchor: [16, 32],
    className: 'form-marker',
  });
  marker = L.marker([4.64, -74.075], { draggable: true, icon: defaultIcon }).addTo(map);
  marker.on('dragend', function() {
    var pos = marker.getLatLng();
    updateInputs(pos.lat, pos.lng);
  });

  function setEstado(txt, tipo) {
    estado.textContent = txt;
    estado.className = 'text-xs ' + (tipo === 'ok' ? 'text-emerald-600 dark:text-emerald-400' : tipo === 'error' ? 'text-red-600 dark:text-red-400' : 'text-stone-500 dark:text-stone-400');
    estado.classList.remove('hidden');
  }

  function setLoading(on) {
    if (on) { btnTxt.textContent = 'Obteniendo...'; btn.disabled = true; btn.classList.add('opacity-50','cursor-not-allowed'); }
    else { btnTxt.textContent = 'Mi ubicacion'; btn.disabled = false; btn.classList.remove('opacity-50','cursor-not-allowed'); }
  }

  function updateInputs(lat, lng) {
    latIn.value = lat.toFixed(7);
    lngIn.value = lng.toFixed(7);
  }

  function placeMarker(lat, lng, acc) {
    var icon = L.icon({
      iconUrl: '/icons/paca.png',
      iconSize: [32, 32],
      iconAnchor: [16, 32],
      className: 'form-marker',
    });
    if (marker) map.removeLayer(marker);
    if (accuracyCircle) map.removeLayer(accuracyCircle);
    marker = L.marker([lat, lng], { draggable: true, icon: icon }).addTo(map);
    marker.on('dragend', function() {
      var pos = marker.getLatLng();
      updateInputs(pos.lat, pos.lng);
    });
    if (acc) {
      accuracyCircle = L.circle([lat, lng], { radius: acc, color: '#059669', fillOpacity: 0.08, weight: 1 }).addTo(map);
    }
    map.setView([lat, lng], 16);
  }

  function onPos(pos) {
    var acc = pos.coords.accuracy;
    if (acc < bestAccuracy) {
      bestAccuracy = acc;
      updateInputs(pos.coords.latitude, pos.coords.longitude);
      placeMarker(pos.coords.latitude, pos.coords.longitude, acc);
    }
    if (acc <= 15) {
      stopWatch();
      btnTxt.textContent = 'GPS preciso';
      setEstado('Precision: ~' + acc.toFixed(0) + 'm', 'ok');
      setLoading(false);
    } else {
      setEstado('Precision: ~' + acc.toFixed(0) + 'm — mejorando...', 'info');
    }
  }

  function onErr(e) {
    if (watchId !== null) return;
    var m = { 1: 'Permiso denegado.', 2: 'Ubicacion no disponible.', 3: 'Intenta de nuevo.' };
    setEstado(m[e.code] || 'Error.', 'error');
    setLoading(false);
  }

  function stopWatch() {
    if (watchId !== null) { navigator.geolocation.clearWatch(watchId); watchId = null; }
  }

  btn.addEventListener('click', function() {
    if (!navigator.geolocation) { setEstado('No soportado.', 'error'); return; }
    stopWatch();
    bestAccuracy = Infinity;
    setLoading(true);
    setEstado('Buscando GPS...', 'info');

    navigator.geolocation.getCurrentPosition(function(pos) {
      onPos(pos);
      if (pos.coords.accuracy > 15) {
        watchId = navigator.geolocation.watchPosition(onPos, function(){}, {
          enableHighAccuracy: true, timeout: 60000, maximumAge: 0
        });
        setTimeout(function() {
          stopWatch();
          if (bestAccuracy < Infinity) { btnTxt.textContent = 'Ubicacion ok'; setEstado('Precision final: ~' + bestAccuracy.toFixed(0) + 'm', bestAccuracy <= 30 ? 'ok' : 'info'); setLoading(false); }
        }, 30000);
      }
    }, onErr, { enableHighAccuracy: true, timeout: 30000, maximumAge: 0 });
  });

  latIn.addEventListener('change', function() {
    var lat = parseFloat(latIn.value);
    var lng = parseFloat(lngIn.value);
    if (!isNaN(lat) && !isNaN(lng)) { placeMarker(lat, lng, null); }
  });
  lngIn.addEventListener('change', function() {
    var lat = parseFloat(latIn.value);
    var lng = parseFloat(lngIn.value);
    if (!isNaN(lat) && !isNaN(lng)) { placeMarker(lat, lng, null); }
  });

  document.getElementById('btn-mover-pin').addEventListener('click', function() {
    var lat = parseFloat(latIn.value);
    var lng = parseFloat(lngIn.value);
    if (!isNaN(lat) && !isNaN(lng)) { placeMarker(lat, lng, null); }
  });

  if (navigator.geolocation && !latIn.value && !lngIn.value) {
    setEstado('Buscando tu ubicacion...', 'info');
    navigator.geolocation.getCurrentPosition(function(pos) {
      var lat = pos.coords.latitude;
      var lng = pos.coords.longitude;
      updateInputs(lat, lng);
      placeMarker(lat, lng, pos.coords.accuracy);
      setEstado('Ubicacion detectada — ajusta el pin si necesario', 'ok');
    }, function() {
      setEstado('No se pudo obtener ubicacion — mueve el pin manualmente', 'info');
    }, { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 });
  } else if (!latIn.value && !lngIn.value) {
    setEstado('Arrastra el pin o ingresa coordenadas', 'info');
  }

  function showError(input, msg) {
    input.classList.add('border-red-500', 'dark:border-red-500');
    input.classList.remove('border-stone-300', 'dark:border-stone-600');
    var err = input.parentElement.querySelector('.error');
    if (err) { err.textContent = msg; err.classList.remove('hidden'); }
  }

  function clearError(input) {
    input.classList.remove('border-red-500', 'dark:border-red-500');
    input.classList.add('border-stone-300', 'dark:border-stone-600');
    var err = input.parentElement.querySelector('.error');
    if (err) err.classList.add('hidden');
  }

  function clearAllErrors() {
    document.querySelectorAll('.field').forEach(clearError);
    document.querySelectorAll('.error').forEach(function(e) { e.classList.add('hidden'); });
  }

  document.querySelectorAll('.field').forEach(function(f) {
    f.addEventListener('input', function() { clearError(f); });
    f.addEventListener('change', function() { clearError(f); });
  });

  function validateForm() {
    clearAllErrors();
    var valid = true;
    var firstError = null;

    var nombre = document.getElementById('nombre');
    if (!nombre.value.trim()) { showError(nombre, 'Ingresa el nombre de la paca'); valid = false; if (!firstError) firstError = nombre; }

    var colectivo = document.getElementById('colectivo');
    if (!colectivo.value) { showError(colectivo, 'Selecciona un colectivo'); valid = false; if (!firstError) firstError = colectivo; }

    var peso = document.getElementById('peso');
    if (!peso.value || parseFloat(peso.value) < 0.1) { showError(peso, 'Ingresa el peso (minimo 0.1 kg)'); valid = false; if (!firstError) firstError = peso; }

    var fecha = document.getElementById('fecha_inicio');
    if (!fecha.value) { showError(fecha, 'Selecciona una fecha'); valid = false; if (!firstError) firstError = fecha; }

    var lat = document.getElementById('coordenadas_lat');
    var lng = document.getElementById('coordenadas_lng');
    if (!lat.value || !lng.value || isNaN(parseFloat(lat.value)) || isNaN(parseFloat(lng.value))) {
      showError(lat, 'Ubica la paca en el mapa o ingresa las coordenadas');
      showError(lng, 'Ubica la paca en el mapa o ingresa las coordenadas');
      valid = false; if (!firstError) firstError = lat;
    }

    var participantes = document.getElementById('participantes');
    if (!participantes.value || parseInt(participantes.value) < 1) { showError(participantes, 'Ingresa el numero de participantes (minimo 1)'); valid = false; if (!firstError) firstError = participantes; }

    var informacion = document.getElementById('informacion');
    if (!informacion.value.trim()) { showError(informacion, 'Agrega informacion sobre la paca'); valid = false; if (!firstError) firstError = informacion; }

    if (firstError) firstError.focus();
    return valid;
  }

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    mensaje.classList.add('hidden');

    if (!validateForm()) return;

    var fd = new FormData(form);
    var data = {};
    fd.forEach(function(v, k) { data[k] = v || null; });
    try {
      var res = await fetch('/api/pacas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      var r = await res.json();
      if (res.ok) {
        mensaje.className = 'rounded-lg p-4 text-sm bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-300';
        mensaje.textContent = 'Paca registrada exitosamente.';
        mensaje.classList.remove('hidden');
        form.reset();
        clearAllErrors();
        if (marker) { map.removeLayer(marker); marker = null; }
        if (accuracyCircle) { map.removeLayer(accuracyCircle); accuracyCircle = null; }
        bestAccuracy = Infinity;
        estado.classList.add('hidden');
        btnTxt.textContent = 'Mi ubicacion';
        marker = L.marker([4.64, -74.075], { draggable: true, icon: defaultIcon }).addTo(map);
        marker.on('dragend', function() { var pos = marker.getLatLng(); updateInputs(pos.lat, pos.lng); });
      } else {
        mensaje.className = 'rounded-lg p-4 text-sm bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300';
        mensaje.textContent = r.error || 'Error al guardar.';
        mensaje.classList.remove('hidden');
      }
    } catch(err) {
      mensaje.className = 'rounded-lg p-4 text-sm bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300';
      mensaje.textContent = 'Error de conexion.';
      mensaje.classList.remove('hidden');
    }
  });
})();
</script>

<style>
  #mapa-form { background: #e5e5e5; }
  :global(.form-marker) { background: transparent !important; border: none !important; }
</style>
