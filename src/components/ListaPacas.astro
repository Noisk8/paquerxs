---
import type { Paca } from '../lib/types';

interface Props {
  pacas: Paca[];
}

const { pacas } = Astro.props;

function formatFecha(fecha: string): string {
  return new Date(fecha).toLocaleDateString('es-CO', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
  {pacas.length === 0 && (
    <p class="col-span-full text-center text-stone-500 dark:text-stone-400 py-12">No hay pacas registradas aun.</p>
  )}
  {pacas.map((paca) => (
    <article class="bg-white dark:bg-stone-800 rounded-xl shadow-sm border border-stone-200 dark:border-stone-700 p-4 sm:p-5 hover:shadow-md transition-shadow">
      <h3 class="font-bold text-emerald-800 dark:text-emerald-400 text-base sm:text-lg leading-tight mb-2">{paca.nombre}</h3>
      <div class="space-y-1 text-sm text-stone-600 dark:text-stone-300">
        <p><span class="font-medium">Colectivo:</span> {paca.colectivo}</p>
        {paca.peso != null && <p><span class="font-medium">Peso:</span> {paca.peso} kg</p>}
        <p><span class="font-medium">Fecha:</span> {formatFecha(paca.fecha_inicio)}</p>
        {paca.participantes != null && <p><span class="font-medium">Participantes:</span> {paca.participantes}</p>}
        {paca.coordenadas_lat != null && paca.coordenadas_lng != null && (
          <p>
            <span class="font-medium">Ubicacion:</span>{' '}
            <a
              href={`https://www.openstreetmap.org/?mlat=${paca.coordenadas_lat}&mlon=${paca.coordenadas_lng}#map=16/${paca.coordenadas_lat}/${paca.coordenadas_lng}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-emerald-600 dark:text-emerald-400 hover:underline"
            >
              Ver en mapa
            </a>
          </p>
        )}
        {paca.informacion && (
          <p class="text-stone-500 dark:text-stone-400 italic mt-2 border-t border-stone-100 dark:border-stone-700 pt-2">{paca.informacion}</p>
        )}
      </div>
      <div class="admin-actions mt-3 flex gap-2 hidden">
        <button
          data-id={paca.id}
          class="btn-eliminar text-xs bg-red-50 dark:bg-red-900 hover:bg-red-100 dark:hover:bg-red-800 text-red-700 dark:text-red-400 px-3 py-1 rounded-lg transition-colors cursor-pointer"
        >
          Eliminar
        </button>
      </div>
    </article>
  ))}
</div>

<script>
  async function checkAdmin() {
    try {
      const res = await fetch('/api/auth/check');
      const data = await res.json();
      if (data.admin) {
        document.querySelectorAll('.admin-actions').forEach((el) => {
          el.classList.remove('hidden');
        });
      }
    } catch {}
  }

  checkAdmin();

  document.querySelectorAll('.btn-eliminar').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const id = (e.target as HTMLElement).dataset.id;
      if (!confirm('Eliminar esta paca?')) return;

      try {
        const res = await fetch(`/api/pacas/${id}`, { method: 'DELETE' });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          alert(data.error || 'Error al eliminar');
        }
      } catch {
        alert('Error de conexion');
      }
    });
  });
</script>
