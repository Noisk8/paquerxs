---
interface Props {
  class?: string;
  lines?: number;
  type?: 'text' | 'card' | 'map' | 'circle' | 'form';
}

const { class: cls = '', lines = 1, type = 'text' } = Astro.props;
---

{type === 'card' && (
  <div class={`bg-white dark:bg-stone-800 rounded-xl border border-stone-200 dark:border-stone-700 p-4 space-y-3 ${cls}`}>
    <div class="skeleton h-4 w-3/4 rounded bg-stone-200 dark:bg-stone-700"></div>
    <div class="space-y-2">
      <div class="skeleton h-3 w-full rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-3 w-5/6 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-3 w-2/3 rounded bg-stone-200 dark:bg-stone-700"></div>
    </div>
    <div class="skeleton h-3 w-1/2 rounded bg-stone-200 dark:bg-stone-700"></div>
  </div>
)}

{type === 'map' && (
  <div class={`relative rounded-xl overflow-hidden border border-stone-200 dark:border-stone-700 ${cls}`}>
    <div class="skeleton-map w-full h-full bg-stone-200 dark:bg-stone-700"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="flex flex-col items-center gap-2">
        <svg class="skeleton-pulse h-8 w-8 text-stone-400 dark:text-stone-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
        </svg>
        <span class="skeleton-pulse text-sm text-stone-400 dark:text-stone-500">Cargando mapa...</span>
      </div>
    </div>
  </div>
)}

{type === 'form' && (
  <div class={`space-y-5 ${cls}`}>
    <div class="skeleton h-7 w-48 rounded bg-stone-200 dark:bg-stone-700"></div>
    <div class="space-y-2">
      <div class="skeleton h-4 w-32 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    </div>
    <div class="space-y-2">
      <div class="skeleton h-4 w-24 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div class="space-y-2">
        <div class="skeleton h-4 w-20 rounded bg-stone-200 dark:bg-stone-700"></div>
        <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
      </div>
      <div class="space-y-2">
        <div class="skeleton h-4 w-20 rounded bg-stone-200 dark:bg-stone-700"></div>
        <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
      </div>
    </div>
    <div class="bg-stone-100 dark:bg-stone-800 rounded-xl p-4 space-y-3">
      <div class="skeleton h-4 w-24 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-[250px] w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
      <div class="grid grid-cols-2 gap-3">
        <div class="skeleton h-10 rounded-lg bg-stone-200 dark:bg-stone-700"></div>
        <div class="skeleton h-10 rounded-lg bg-stone-200 dark:bg-stone-700"></div>
      </div>
    </div>
    <div class="space-y-2">
      <div class="skeleton h-4 w-36 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-10 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    </div>
    <div class="space-y-2">
      <div class="skeleton h-4 w-40 rounded bg-stone-200 dark:bg-stone-700"></div>
      <div class="skeleton h-20 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
    </div>
    <div class="skeleton h-12 w-full rounded-lg bg-stone-200 dark:bg-stone-700"></div>
  </div>
)}

{type === 'text' && (
  <div class={`space-y-2 ${cls}`}>
    {Array.from({ length: lines }).map(() => (
      <div class="skeleton h-4 rounded bg-stone-200 dark:bg-stone-700" style={`width: ${60 + Math.random() * 40}%`}></div>
    ))}
  </div>
)}

{type === 'circle' && (
  <div class={`skeleton skeleton-pulse rounded-full bg-stone-200 dark:bg-stone-700 ${cls}`}></div>
)}
