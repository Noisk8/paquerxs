---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  titulo: string;
}

const { titulo } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#065f46" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Paquerxs" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <title>{titulo} | Paquerxs</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-stone-50 dark:bg-stone-900 text-stone-800 dark:text-stone-200 min-h-screen flex flex-col transition-colors">
    <nav class="bg-emerald-800 dark:bg-emerald-900 text-white shadow-lg relative z-50">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-lg sm:text-xl font-bold tracking-tight hover:text-emerald-200 transition-colors">
          Paquerxs
        </a>
        <div class="flex items-center gap-1">
          <ThemeToggle />
          <button
            id="menu-toggle"
            class="sm:hidden p-2 rounded-lg hover:bg-emerald-700 transition-colors cursor-pointer"
            aria-label="Menu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <div id="nav-menu" class="hidden sm:flex gap-1 text-sm">
            <a href="/" class="px-3 py-2 rounded-lg hover:bg-emerald-700 transition-colors">Mapa</a>
            <a href="/pacas" class="px-3 py-2 rounded-lg hover:bg-emerald-700 transition-colors">Pacas</a>
            <a href="/formulario" class="px-3 py-2 rounded-lg hover:bg-emerald-700 transition-colors">Registrar</a>
            <a href="/about" class="px-3 py-2 rounded-lg hover:bg-emerald-700 transition-colors">About</a>
            <a href="/admin" class="px-3 py-2 rounded-lg hover:bg-emerald-700 transition-colors">Admin</a>
          </div>
        </div>
      </div>
      <div id="nav-mobile" class="hidden sm:hidden border-t border-emerald-700 px-4 pb-3">
        <a href="/" class="block py-2 hover:text-emerald-200 transition-colors">Mapa</a>
        <a href="/pacas" class="block py-2 hover:text-emerald-200 transition-colors">Pacas</a>
        <a href="/formulario" class="block py-2 hover:text-emerald-200 transition-colors">Registrar</a>
        <a href="/about" class="block py-2 hover:text-emerald-200 transition-colors">About</a>
        <a href="/admin" class="block py-2 hover:text-emerald-200 transition-colors">Admin</a>
      </div>
    </nav>
    <main class="max-w-6xl mx-auto px-4 py-6 sm:py-8 w-full flex-1">
      <slot />
    </main>
    <footer class="bg-stone-200 dark:bg-stone-800 text-stone-600 dark:text-stone-400 text-center py-4 text-xs sm:text-sm transition-colors">
      Paquerxs Teusaquillo &middot; Monitoreo de Pacas
    </footer>

    <div id="pwa-install" class="hidden fixed bottom-0 inset-x-0 z-50 p-4">
      <div class="max-w-md mx-auto bg-emerald-700 dark:bg-emerald-800 text-white rounded-xl shadow-2xl p-4 flex items-center gap-3">
        <img src="/icons/paca.png" alt="" class="w-10 h-10 rounded-lg" />
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-sm">Instalar Paquerxs</p>
          <p class="text-emerald-100 text-xs">Acceso rapido desde tu pantalla de inicio</p>
        </div>
        <button id="pwa-install-btn" class="bg-white text-emerald-700 font-bold text-xs px-3 py-2 rounded-lg hover:bg-emerald-50 transition-colors cursor-pointer whitespace-nowrap">
          Instalar
        </button>
        <button id="pwa-dismiss-btn" class="text-emerald-200 hover:text-white text-xs px-2 py-2 cursor-pointer" aria-label="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
  </body>
</html>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const mobile = document.getElementById('nav-mobile')!;

  toggle.addEventListener('click', () => {
    mobile.classList.toggle('hidden');
  });

  document.querySelectorAll('#nav-mobile a').forEach((link) => {
    link.addEventListener('click', () => {
      mobile.classList.add('hidden');
    });
  });

  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }

  var deferredPrompt = null;
  var installEl = document.getElementById('pwa-install');
  var installBtn = document.getElementById('pwa-install-btn');
  var dismissBtn = document.getElementById('pwa-dismiss-btn');

  window.addEventListener('beforeinstallprompt', function(e) {
    e.preventDefault();
    deferredPrompt = e;
    if (!localStorage.getItem('pwa-dismissed')) {
      installEl.classList.remove('hidden');
    }
  });

  installBtn.addEventListener('click', function() {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    deferredPrompt.userChoice.then(function(choice) {
      if (choice.outcome === 'accepted') {
        installEl.classList.add('hidden');
      }
      deferredPrompt = null;
    });
  });

  dismissBtn.addEventListener('click', function() {
    installEl.classList.add('hidden');
    localStorage.setItem('pwa-dismissed', '1');
  });

  window.addEventListener('appinstalled', function() {
    installEl.classList.add('hidden');
    deferredPrompt = null;
  });
</script>
