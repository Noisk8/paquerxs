---
import Layout from '../layouts/Layout.astro';
import { getAllPacas } from '../lib/db';

export const prerender = false;

let pacas = [];
try {
  pacas = await getAllPacas(500, 0);
} catch (e) {
  console.error('Error loading pacas:', e);
}

const pacasJSON = JSON.stringify(pacas);
---

<Layout titulo="Inventario de Pacas">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-3xl font-bold text-stone-800 dark:text-stone-100">Inventario de Pacas</h1>
      <p class="text-stone-500 dark:text-stone-400 mt-1"><span id="contador">{pacas.length}</span> pacas</p>
    </div>
    <a href="/formulario" class="bg-emerald-700 hover:bg-emerald-800 text-white font-semibold py-2 px-4 rounded-lg transition-colors text-sm">
      + Nueva Paca
    </a>
  </div>

  <div class="flex flex-col sm:flex-row gap-3 mb-6">
    <select id="filtro-colectivo" class="rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 outline-none bg-white flex-1 sm:flex-none sm:w-56">
      <option value="">Todos los colectivos</option>
      <option value="Paquerxs del Parkway">Parkway</option>
      <option value="Paquerxs de San Luis">San Luis</option>
      <option value="Paquerxs del Neuque">Neuque</option>
      <option value="Paquerxs de La Marchita">La Marchita</option>
      <option value="Paquerxs Armenia">Armenia</option>
    </select>
    <input type="text" id="filtro-nombre" placeholder="Buscar por nombre..." class="rounded-lg border-stone-300 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-200 border px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 outline-none flex-1" />
    <div class="flex border border-stone-300 dark:border-stone-600 rounded-lg overflow-hidden">
      <button id="btn-vista-tarjetas" class="vista-btn px-3 py-2 text-sm bg-emerald-600 text-white cursor-pointer" title="Vista tarjetas">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      </button>
      <button id="btn-vista-tabla" class="vista-btn px-3 py-2 text-sm bg-white dark:bg-stone-800 text-stone-600 dark:text-stone-400 cursor-pointer" title="Vista tabla">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <div id="vista-tarjetas" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
    {Array.from({ length: 6 }).map(() => (
      <div class="bg-white dark:bg-stone-800 rounded-xl border border-stone-200 dark:border-stone-700 p-4 space-y-3">
        <div class="skeleton h-4 w-3/4 rounded bg-stone-200 dark:bg-stone-700"></div>
        <div class="space-y-2">
          <div class="skeleton h-3 w-full rounded bg-stone-200 dark:bg-stone-700"></div>
          <div class="skeleton h-3 w-5/6 rounded bg-stone-200 dark:bg-stone-700"></div>
          <div class="skeleton h-3 w-2/3 rounded bg-stone-200 dark:bg-stone-700"></div>
        </div>
        <div class="skeleton h-3 w-1/2 rounded bg-stone-200 dark:bg-stone-700"></div>
      </div>
    ))}
  </div>

  <div id="vista-tabla" class="hidden overflow-x-auto">
    <table class="w-full text-sm text-left">
      <thead class="text-xs text-stone-500 dark:text-stone-400 uppercase bg-stone-50 dark:bg-stone-800 border-b border-stone-200 dark:border-stone-700">
        <tr>
          <th class="px-4 py-3">Nombre</th>
          <th class="px-4 py-3 hidden sm:table-cell">Colectivo</th>
          <th class="px-4 py-3 hidden md:table-cell">Peso</th>
          <th class="px-4 py-3">Fecha</th>
          <th class="px-4 py-3 hidden lg:table-cell">Part.</th>
          <th class="px-4 py-3 hidden lg:table-cell">Info</th>
          <th class="px-4 py-3 text-right">Acciones</th>
        </tr>
      </thead>
      <tbody id="tabla-body" class="divide-y divide-stone-100 dark:divide-stone-700"></tbody>
    </table>
  </div>

  <p id="sin-resultados" class="hidden text-center text-stone-500 dark:text-stone-400 py-12">No se encontraron pacas.</p>
</Layout>

<script define:vars={{ pacasJSON }}>
  const pacas = JSON.parse(pacasJSON);
  let vistaActual = 'tarjetas';

  const tarjetasEl = document.getElementById('vista-tarjetas');
  const tablaEl = document.getElementById('vista-tabla');
  const tablaBody = document.getElementById('tabla-body');
  const sinResultados = document.getElementById('sin-resultados');
  const contador = document.getElementById('contador');
  const filtroColectivo = document.getElementById('filtro-colectivo');
  const filtroNombre = document.getElementById('filtro-nombre');
  const btnTarjetas = document.getElementById('btn-vista-tarjetas');
  const btnTabla = document.getElementById('btn-vista-tabla');

  function fmt(fecha) {
    return new Date(fecha).toLocaleDateString('es-CO', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function filtrar() {
    const col = filtroColectivo.value;
    const nom = filtroNombre.value.toLowerCase();
    return pacas.filter(p => {
      const matchCol = !col || p.colectivo === col;
      const matchNom = !nom || p.nombre.toLowerCase().includes(nom);
      return matchCol && matchNom;
    });
  }

  function renderTarjetas(lista) {
    if (lista.length === 0) { tarjetasEl.innerHTML = ''; return; }
    tarjetasEl.innerHTML = lista.map(p => {
      const peso = p.peso != null ? p.peso + ' kg' : '-';
      const part = p.participantes != null ? p.participantes : '-';
      const coord = p.coordenadas_lat != null ? `<p class="text-stone-500 dark:text-stone-400 text-xs mt-1"><a href="https://www.openstreetmap.org/?mlat=${p.coordenadas_lat}&mlon=${p.coordenadas_lng}#map=16/${p.coordenadas_lat}/${p.coordenadas_lng}" target="_blank" class="text-emerald-600 dark:text-emerald-400 hover:underline">Ver en mapa</a></p>` : '';
      const info = p.informacion ? `<p class="text-stone-500 dark:text-stone-400 italic text-xs mt-1 border-t border-stone-100 dark:border-stone-700 pt-1">${p.informacion}</p>` : '';
      return `<article class="bg-white dark:bg-stone-800 rounded-xl shadow-sm border border-stone-200 dark:border-stone-700 p-4 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-emerald-800 dark:text-emerald-400 text-sm leading-tight mb-2">${p.nombre}</h3>
        <div class="space-y-0.5 text-xs text-stone-600 dark:text-stone-300">
          <p><b>Colectivo:</b> ${p.colectivo}</p>
          <p><b>Peso:</b> ${peso}</p>
          <p><b>Fecha:</b> ${fmt(p.fecha_inicio)}</p>
          <p><b>Part.:</b> ${part}</p>
        </div>
        ${coord}${info}
        <div class="admin-actions mt-2 hidden">
          <button data-id="${p.id}" class="btn-eliminar text-xs bg-red-50 dark:bg-red-900 hover:bg-red-100 dark:hover:bg-red-800 text-red-700 dark:text-red-400 px-3 py-1 rounded-lg cursor-pointer">Eliminar</button>
        </div>
      </article>`;
    }).join('');
  }

  function renderTabla(lista) {
    if (lista.length === 0) { tablaBody.innerHTML = ''; return; }
    tablaBody.innerHTML = lista.map(p => {
      const peso = p.peso != null ? p.peso + ' kg' : '-';
      const part = p.participantes != null ? p.participantes : '-';
      const info = p.informacion || '';
      return `<tr class="bg-white dark:bg-stone-900 border-b border-stone-100 dark:border-stone-800 hover:bg-stone-50 dark:hover:bg-stone-800">
        <td class="px-4 py-3 font-medium text-stone-800 dark:text-stone-200 text-sm max-w-[200px] truncate">${p.nombre}</td>
        <td class="px-4 py-3 text-stone-600 dark:text-stone-400 hidden sm:table-cell">${p.colectivo}</td>
        <td class="px-4 py-3 text-stone-600 dark:text-stone-400 hidden md:table-cell">${peso}</td>
        <td class="px-4 py-3 text-stone-600 dark:text-stone-400 whitespace-nowrap">${fmt(p.fecha_inicio)}</td>
        <td class="px-4 py-3 text-stone-600 dark:text-stone-400 hidden lg:table-cell">${part}</td>
        <td class="px-4 py-3 text-stone-500 dark:text-stone-400 text-xs max-w-[150px] truncate hidden lg:table-cell">${info}</td>
        <td class="px-4 py-3 text-right"><button data-id="${p.id}" class="btn-eliminar text-xs bg-red-50 dark:bg-red-900 hover:bg-red-100 dark:hover:bg-red-800 text-red-700 dark:text-red-400 px-2 py-1 rounded-lg cursor-pointer admin-actions hidden">Eliminar</button></td>
      </tr>`;
    }).join('');
  }

  function render() {
    const lista = filtrar();
    contador.textContent = lista.length;
    sinResultados.classList.toggle('hidden', lista.length > 0);
    renderTarjetas(lista);
    renderTabla(lista);
    checkAdmin();
  }

  function setVista(vista) {
    vistaActual = vista;
    tarjetasEl.classList.toggle('hidden', vista !== 'tarjetas');
    tablaEl.classList.toggle('hidden', vista !== 'tabla');
    btnTarjetas.className = 'vista-btn px-3 py-2 text-sm cursor-pointer ' + (vista === 'tarjetas' ? 'bg-emerald-600 text-white' : 'bg-white dark:bg-stone-800 text-stone-600 dark:text-stone-400');
    btnTabla.className = 'vista-btn px-3 py-2 text-sm cursor-pointer ' + (vista === 'tabla' ? 'bg-emerald-600 text-white' : 'bg-white dark:bg-stone-800 text-stone-600 dark:text-stone-400');
  }

  async function checkAdmin() {
    try {
      const res = await fetch('/api/auth/check');
      const data = await res.json();
      if (data.admin) {
        document.querySelectorAll('.admin-actions').forEach(el => el.classList.remove('hidden'));
      }
    } catch {}
  }

  btnTarjetas.addEventListener('click', () => setVista('tarjetas'));
  btnTabla.addEventListener('click', () => setVista('tabla'));
  filtroColectivo.addEventListener('change', render);
  filtroNombre.addEventListener('input', render);

  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('.btn-eliminar');
    if (!btn) return;
    if (!confirm('Eliminar esta paca?')) return;
    try {
      const res = await fetch('/api/pacas/' + btn.dataset.id, { method: 'DELETE' });
      if (res.ok) window.location.reload();
      else alert('Error al eliminar');
    } catch { alert('Error de conexion'); }
  });

  render();
</script>
